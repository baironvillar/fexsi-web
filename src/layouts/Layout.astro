---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Fexsi SpA | Soluciones Metalúrgicas de Excelencia" } =
	Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Fexsi SpA - Soluciones Metalúrgicas de Excelencia en Antofagasta. Maestranza, Calderería y Obras Civiles para la Gran Minería."
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />

		<!-- Google Fonts: Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="font-sans antialiased text-slate-800 bg-slate-50 min-h-screen flex flex-col selection:bg-orange-500 selection:text-white overflow-x-hidden relative"
	>
		<!-- Background fijo para la parte blanca -->
		<div class="fixed inset-0 z-[-1] pointer-events-none">
			<img
				src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=2070&auto=format&fit=crop&fm=webp"
				alt="Fondo Industrial"
				class="w-full h-full object-cover opacity-[0.08] grayscale"
			/>
		</div>

		<slot />

		<script>
			function initScrollReveal() {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("active");
							}
						});
					},
					{ threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
				);

				document
					.querySelectorAll(".reveal, .reveal-left, .reveal-right")
					.forEach((el) => {
						observer.observe(el);
					});
			}

			// Ejecutar inicialización
			initScrollReveal();

			// Manejar smooth scroll manualmente para evitar conflictos con View Transitions al recargar o volver
			function initSmoothScroll() {
				document
					.querySelectorAll('a[href^="/#"], a[href^="#"]')
					.forEach((anchor) => {
						// Prevenir que se vuelva a agregar el listener si Astro vuelve a ejecutar este script
						anchor.removeEventListener("click", handleSmoothScroll);
						anchor.addEventListener("click", handleSmoothScroll);
					});
			}

			function handleSmoothScroll(this: HTMLElement, e: Event) {
				const target = e.currentTarget as HTMLAnchorElement | null;
				if (!target || !target.href) return;

				const targetUrl = new URL(target.href, window.location.origin);
				if (targetUrl.pathname === window.location.pathname && targetUrl.hash) {
					e.preventDefault();
					const targetElement = document.querySelector(targetUrl.hash);
					if (targetElement) {
						targetElement.scrollIntoView({ behavior: "smooth" });
						history.pushState(null, "", targetUrl.hash);
					}
				}
			}

			initSmoothScroll();

			// Re-ejecutar cuando naveguemos vía View Transitions / ClientRouter
			document.addEventListener("astro:page-load", () => {
				initScrollReveal();
				initSmoothScroll();
			});
		</script>
	</body>
</html>
