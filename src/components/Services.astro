---
const services = [
  {
    title: "Maestranza",
    description:
      "Servicios de mecanizado de alta precisión para fabricación y recuperación de piezas industriales con tornos, fresadoras y mandrinadoras.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
  {
    title: "Calderería",
    description:
      "Fabricación de estructuras metálicas pesadas, estanques, tolvas y ductos. Soldadura especializada y certificada.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z" />`,
  },
  {
    title: "Obras Civiles",
    description:
      "Desarrollo de proyectos de infraestructura para minería, montajes industriales y fundaciones para equipos pesados.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
  },
  {
    title: "Reparación y Mantención",
    description:
      "Mantenimiento integral y reparación de equipos mineros, palas, perforadoras y maquinaria pesada en terreno o maestranza.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />`,
  },
];
---

<section id="servicios" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <h2
        class="text-orange-600 font-semibold tracking-wide uppercase text-sm mb-3"
      >
        Nuestras Capacidades
      </h2>
      <h3 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6">
        Servicios Integrales de Ingeniería
      </h3>
      <p class="text-lg text-slate-600">
        Proveemos soluciones robustas y confiables para la industria minera y
        manufacturera, respaldadas por un equipo altamente calificado.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        services.map((service, index) => (
          <div
            class={`group p-8 bg-slate-50 rounded-2xl border border-slate-100 hover:bg-white hover:shadow-xl hover:shadow-orange-600/5 hover:-translate-y-1 transition-all duration-300 reveal delay-${
              ((index % 4) + 1) * 100
            }`}
          >
            <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center mb-6 group-hover:bg-orange-600 transition-colors duration-300">
              <svg
                class="w-7 h-7 text-orange-600 group-hover:text-white transition-colors duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                set:html={service.icon}
              />
            </div>
            <h4 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-orange-600 transition-colors">
              {service.title}
            </h4>
            <p class="text-slate-600 text-sm leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
