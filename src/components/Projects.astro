---
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<section id="proyectos" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8 reveal-left"
    >
      <div class="max-w-2xl">
        <h2
          class="text-orange-600 font-semibold tracking-wide uppercase text-sm mb-3"
        >
          Casos de Éxito
        </h2>
        <h3 class="text-3xl md:text-5xl font-bold text-slate-900">
          Proyectos Destacados
        </h3>
      </div>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 text-orange-600 font-semibold hover:text-orange-700 transition-colors"
      >
        Inicie su proyecto
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        projects.map(
          (project: import("astro:content").CollectionEntry<"projects">, index: number) => (
            <a
              href={`/proyectos/${project.id}`}
              class="group relative rounded-2xl overflow-hidden aspect-[4/5] cursor-pointer block"
            >
              <img
                src={project.data.coverImage}
                alt={project.data.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/40 to-transparent" />
              <div class="absolute bottom-0 left-0 p-8 w-full translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                <p class="text-orange-400 font-medium text-sm mb-2">
                  {project.data.category}
                </p>
                <h4 class="text-2xl font-bold text-white mb-2">
                  {project.data.title}
                </h4>
                <div class="h-1 w-12 bg-orange-600 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100" />
              </div>
            </a>
          )
        )
      }
    </div>
  </div>
</section>
