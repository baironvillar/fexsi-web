---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 border-t border-white/5 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2">
        <div
          class="w-10 h-10 bg-white rounded flex items-center justify-center"
        >
          <img
            src="/images/logo-fexsi.webp"
            alt="Logo Fexsi"
            class="w-10 h-10 rounded-lg"
          />
        </div>
        <span class="text-xl font-bold text-white tracking-tight"
          >FEXSI<span class="text-orange-600">.</span>
        </span>
      </div>

      <p class="text-slate-500 text-sm text-center md:text-left">
        &copy; {currentYear} Fexsi SpA. Todos los derechos reservados.
      </p>

      <div class="flex gap-4">
        <a
          href="#"
          class="text-slate-500 hover:text-white transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
