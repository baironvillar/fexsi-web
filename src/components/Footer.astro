---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 border-t border-white/5 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 mb-12">
      <!-- Col 1: Logo and Info -->
      <div class="lg:col-span-4 flex flex-col">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-12 h-12 bg-white rounded-lg flex items-center justify-center"
          >
            <img
              src="/images/logo-fexsi.webp"
              alt="Logo Fexsi"
              class="w-12 h-12 rounded-lg"
            />
          </div>
          <span class="text-2xl font-bold text-white tracking-tight"
            >FEXSI<span class="text-orange-600">.</span>
          </span>
        </div>
        <p class="text-slate-400 mb-8 leading-relaxed pr-4">
          Expertos en maestranza, calderería y obras civiles para el sector
          industrial y la gran minería en la región de Antofagasta.
        </p>
        <div class="flex gap-4">
          <a
            href="mailto:operaciones@fexsi.cl"
            class="text-slate-400 hover:text-white transition-all flex items-center justify-center w-10 h-10 bg-white/5 rounded-lg hover:bg-orange-600"
            aria-label="Enviar correo"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </a>
          <a
            href="https://wa.me/56963719477"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-400 hover:text-white transition-all flex items-center justify-center w-10 h-10 bg-white/5 rounded-lg hover:bg-[#25D366]"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 448 512">
              <path
                d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zM223.9 411.4c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 331.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7 .9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Navigation -->
      <div class="lg:col-span-3 flex flex-col">
        <h4 class="text-white text-lg font-semibold mb-6">Enlaces Rápidos</h4>
        <ul class="space-y-4">
          <li>
            <a
              href="/#servicios"
              class="text-slate-400 hover:text-orange-500 transition-colors inline-flex items-center"
              ><span class="w-2 h-2 rounded-full bg-orange-600/50 mr-3"></span> Servicios</a
            >
          </li>
          <li>
            <a
              href="/#nosotros"
              class="text-slate-400 hover:text-orange-500 transition-colors inline-flex items-center"
              ><span class="w-2 h-2 rounded-full bg-orange-600/50 mr-3"></span> Quiénes
              Somos</a
            >
          </li>
          <li>
            <a
              href="/#proyectos"
              class="text-slate-400 hover:text-orange-500 transition-colors inline-flex items-center"
              ><span class="w-2 h-2 rounded-full bg-orange-600/50 mr-3"></span> Casos
              de Éxito</a
            >
          </li>
          <li>
            <a
              href="/#contacto"
              class="text-slate-400 hover:text-orange-500 transition-colors inline-flex items-center"
              ><span class="w-2 h-2 rounded-full bg-orange-600/50 mr-3"></span> Contacto</a
            >
          </li>
        </ul>
      </div>

      <!-- Col 3: Map Location -->
      <div class="lg:col-span-5 flex flex-col">
        <h4 class="text-white text-lg font-semibold mb-6">Nuestra Ubicación</h4>
        <div
          class="w-full h-48 rounded-xl overflow-hidden bg-slate-800 border border-white/5 shadow-inner group relative"
        >
          <iframe
            width="100%"
            height="100%"
            frameborder="0"
            title="Mapa ubicación Fexsi"
            src="https://maps.google.com/maps?q=Uribe%20636,%20Antofagasta,%20Chile&t=&z=16&ie=UTF8&iwloc=&output=embed"
            class="opacity-80 group-hover:opacity-100 transition-opacity duration-500 filter contrast-125 saturate-50"
          ></iframe>
        </div>
        <p class="text-slate-400 text-sm mt-5 flex items-start gap-3">
          <svg
            class="w-5 h-5 text-orange-500 flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          Uribe 636 Of 509 Centro De Negocios, Antofagasta
        </p>
      </div>
    </div>

    <!-- Divider -->
    <div
      class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-slate-500 text-sm text-center md:text-left">
        &copy; {currentYear} Fexsi SpA. Todos los derechos reservados.
      </p>
      <p class="text-slate-500 text-sm">
        Desarrollado por <a
          href="https://linkedin.com/in/baironvillarberrios"
          target="_blank"
          rel="noopener noreferrer"
          class="text-orange-500 hover:text-orange-600 transition-colors"
          >Bairon Villar</a
        >
      </p>
    </div>
  </div>
</footer>
