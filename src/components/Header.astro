---
---

<header
  class="fixed w-full z-50 transition-all duration-300 bg-white/90 backdrop-blur-md shadow-sm border-b border-slate-200/50"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center gap-2">
        <div
          class="w-10 h-10 bg-white rounded-lg flex items-center justify-center"
        >
          <img
            src="/images/logo-fexsi.webp"
            alt="Logo Fexsi"
            class="w-10 h-10 rounded-lg"
          />
        </div>
        <a href="#" class="text-2xl font-bold text-slate-900 tracking-tight"
          >FEXSI<span class="text-orange-600">.</span>
        </a>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a
          href="/#servicios"
          class="text-sm font-medium text-slate-600 hover:text-orange-600 transition-colors"
          >Servicios</a
        >
        <a
          href="/#nosotros"
          class="text-sm font-medium text-slate-600 hover:text-orange-600 transition-colors"
          >Nosotros</a
        >
        <a
          href="/#proyectos"
          class="text-sm font-medium text-slate-600 hover:text-orange-600 transition-colors"
          >Proyectos</a
        >
        <a
          href="/#contacto"
          class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white transition-all bg-orange-600 rounded-lg hover:bg-orange-700 hover:shadow-lg hover:shadow-orange-600/20 hidden lg:inline-flex"
        >
          Cotizar Proyecto
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <div class="flex items-center lg:hidden">
        <button
          type="button"
          id="mobile-menu-btn"
          class="text-slate-600 hover:text-orange-600 focus:outline-none"
          aria-label="Toggle menu"
        >
          <svg
            class="h-8 w-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white/95 backdrop-blur-md border-t border-slate-100 absolute w-full left-0 shadow-lg top-full origin-top transition-all duration-300"
  >
    <div class="px-4 py-4 space-y-2 flex flex-col">
      <a
        href="/#servicios"
        class="mobile-link px-4 py-3 text-base font-medium text-slate-700 hover:text-orange-600 hover:bg-slate-50 rounded-lg"
        >Servicios</a
      >
      <a
        href="/#nosotros"
        class="mobile-link px-4 py-3 text-base font-medium text-slate-700 hover:text-orange-600 hover:bg-slate-50 rounded-lg"
        >Nosotros</a
      >
      <a
        href="/#proyectos"
        class="mobile-link px-4 py-3 text-base font-medium text-slate-700 hover:text-orange-600 hover:bg-slate-50 rounded-lg"
        >Proyectos</a
      >
      <a
        href="/#contacto"
        class="mobile-link px-4 py-3 text-base font-bold text-white bg-orange-600 hover:bg-orange-700 rounded-lg text-center mt-4"
        >Cotizar Proyecto</a
      >
    </div>
  </div>
</header>

<script>
  function initHeaderMenu() {
    const mobileBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const links = document.querySelectorAll(".mobile-link");

    if (mobileBtn && mobileMenu) {
      const newBtn = mobileBtn.cloneNode(true) as HTMLButtonElement;
      mobileBtn.parentNode?.replaceChild(newBtn, mobileBtn);

      newBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
      });

      // Close menu when clicking a link
      links.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
        });
      });
    }
  }

  initHeaderMenu();
  document.addEventListener("astro:page-load", initHeaderMenu);
</script>
