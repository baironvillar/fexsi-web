---
---

<section id="contacto" class="py-24 bg-slate-900 relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3">
    <div class="w-96 h-96 bg-orange-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Contact Info -->
      <div class="reveal-left">
        <h2
          class="text-orange-500 font-semibold tracking-wide uppercase text-sm mb-3"
        >
          Contáctenos
        </h2>
        <h3 class="text-3xl md:text-5xl font-bold text-white mb-8">
          Soluciones para la Gran Industria
        </h3>
        <p class="text-slate-400 text-lg mb-12">
          ¿Tiene un proyecto en mente o requiere servicios metalúrgicos
          especializados? Nuestro equipo de expertos está listo para asesorarle.
        </p>

        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center flex-shrink-0 border border-white/10"
            >
              <svg
                class="w-6 h-6 text-orange-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h4 class="text-white font-semibold text-lg">Dirección</h4>
              <p class="text-slate-400 mt-1">
                Uribe 636 Of 509 C. De Negocios<br />Antofagasta, Chile
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center flex-shrink-0 border border-white/10"
            >
              <svg
                class="w-6 h-6 text-orange-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <h4 class="text-white font-semibold text-lg">Email</h4>
              <p class="text-slate-400 mt-1">operaciones@fexsi.cl</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 bg-white/5 rounded-lg flex items-center justify-center flex-shrink-0 border border-white/10"
            >
              <svg
                class="w-6 h-6 text-orange-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <h4 class="text-white font-semibold text-lg">Teléfono</h4>
              <p class="text-slate-400 mt-1">+56 9 6371 9477</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-2xl p-8 shadow-2xl shadow-black/50 reveal-right">
        <h4 class="text-2xl font-bold text-slate-900 mb-6">
          Envíenos un mensaje
        </h4>
        <form id="contact-form" class="space-y-6">
          <input
            type="hidden"
            name="access_key"
            value="30b97354-2f06-4bab-baa2-5c7e688fba15"
          />
          <input
            type="hidden"
            id="subject"
            name="subject"
            value="Mensaje desde Fexsi.cl"
          />
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display: none;"
          />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-slate-700 mb-2"
                >Nombre completo</label
              >
              <input
                type="text"
                id="name"
                name="Nombre"
                required
                class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:ring-2 focus:ring-orange-600 focus:border-orange-600 transition-colors"
                placeholder="Ej: Juan Pérez"
              />
            </div>
            <div>
              <label
                for="company"
                class="block text-sm font-medium text-slate-700 mb-2"
                >Empresa</label
              >
              <input
                type="text"
                id="company"
                name="Empresa"
                class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:ring-2 focus:ring-orange-600 focus:border-orange-600 transition-colors"
                placeholder="Su empresa"
              />
            </div>
          </div>

          <div>
            <label
              for="email"
              class="block text-sm font-medium text-slate-700 mb-2"
              >Correo electrónico</label
            >
            <input
              type="email"
              id="email"
              name="Email"
              required
              class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:ring-2 focus:ring-orange-600 focus:border-orange-600 transition-colors"
              placeholder="correo@empresa.cl"
            />
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-slate-700 mb-2"
              >Mensaje o Requerimiento</label
            >
            <textarea
              id="message"
              name="Mensaje"
              required
              rows="4"
              class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:ring-2 focus:ring-orange-600 focus:border-orange-600 transition-colors resize-none"
              placeholder="Describa su proyecto o necesidad..."></textarea>
          </div>

          <button
            type="submit"
            id="submit-button"
            class="w-full py-4 px-6 rounded-lg bg-orange-600 hover:bg-orange-700 text-white font-bold text-lg shadow-lg shadow-orange-600/20 hover:shadow-xl hover:shadow-orange-600/30 hover:-translate-y-0.5 transition-all disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:-translate-y-0 flex justify-center items-center gap-2"
          >
            <span id="button-text">Enviar Mensaje</span>
            <svg
              id="loading-spinner"
              class="animate-spin hidden w-5 h-5 text-white"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg>
          </button>

          <p
            id="form-status"
            class="hidden text-center font-medium mt-4 p-3 rounded-lg"
          >
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const statusEl = document.getElementById("form-status");
    const submitButton = document.getElementById(
      "submit-button"
    ) as HTMLButtonElement;
    const buttonText = document.getElementById("button-text");
    const spinner = document.getElementById("loading-spinner");

    if (form) {
      // Remover listener viejo si existe (clonando el form)
      const newForm = form.cloneNode(true) as HTMLFormElement;
      form.parentNode?.replaceChild(newForm, form);

      newForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (!statusEl || !submitButton || !buttonText || !spinner) return;

        submitButton.disabled = true;
        buttonText.textContent = "Enviando...";
        spinner.classList.remove("hidden");
        statusEl.classList.add("hidden");
        statusEl.className = "hidden text-center font-medium mt-4 p-3 rounded-lg";

        const formData = new FormData(newForm);

        // Asignar el asunto dinámicamente incluyendo el email
        const emailValue = formData.get("Email") || "Contacto";
        formData.set("subject", `Mensaje desde Fexsi.cl - ${emailValue}`);

        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: json,
          });

          const result = await response.json();
          statusEl.classList.remove("hidden");

          if (response.status === 200) {
            statusEl.textContent =
              "¡Mensaje enviado con éxito! Nos pondremos en contacto pronto.";
            statusEl.classList.add("bg-green-100", "text-green-700");
            newForm.reset();
          } else {
            console.error(result);
            statusEl.textContent =
              "Hubo un error al enviar el mensaje. Por favor intente más tarde.";
            statusEl.classList.add("bg-red-100", "text-red-700");
          }
        } catch (error) {
          console.error(error);
          statusEl.classList.remove("hidden");
          statusEl.textContent =
            "Error de conexión. Verifique su internet e intente nuevamente.";
          statusEl.classList.add("bg-red-100", "text-red-700");
        } finally {
          submitButton.disabled = false;
          buttonText.textContent = "Enviar Mensaje";
          spinner.classList.add("hidden");

          if (statusEl.classList.contains("bg-green-100")) {
            setTimeout(() => {
              statusEl.classList.add("hidden");
            }, 5000);
          }
        }
      });
    }
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
